{
  "name": "@libra/auth",
  "version": "1.0.6",
  "private": true,
  "main": "auth-server.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./auth-server.ts"
    },
    "./auth-client": {
      "types": "./auth-client.ts",
      "default": "./auth-client.ts"
    },
    "./auth-server": {
      "types": "./auth-server.ts",
      "default": "./auth-server.ts"
    },
    "./db": {
      "types": "./db/index.ts",
      "default": "./db/index.ts"
    },
    "./db/schema/*": {
      "types": "./db/schema/*.ts",
      "default": "./db/schema/*.ts"
    },
    "./env.mjs": {
      "types": "./env.mjs",
      "default": "./env.mjs"
    },
    "./plugins": {
      "types": "./plugins.ts",
      "default": "./plugins.ts"
    },
    "./utils/*": {
      "types": "./utils/*.ts",
      "default": "./utils/*.ts"
    }
  },
  "scripts": {
    "auth:generate": "NODE_OPTIONS=--experimental-detect-module bun with-env bunx @better-auth/cli generate --config auth-server.ts --output ./db/schema/auth-schema.ts -y",
    "db:generate": "bun with-env drizzle-kit generate",
    "db:migrate": "bun with-env bunx drizzle-kit migrate",
    "db:migrate-remote": "bun with-env wrangler d1 migrations apply libra --remote",
    "db:studio": "bun with-env drizzle-kit studio --port 3002",
    "test": "bun with-env vitest",
    "test:watch": "bun with-env vitest watch",
    "test:coverage": "bun with-env vitest --coverage",
    "with-env": "dotenv -e ../../.env --",
    "update": "bun update"
  },
  "dependencies": {
    "@libra/better-auth-cloudflare": "*",
    "@libra/better-auth-stripe": "*",
    "@libra/common": "*",
    "@libra/db": "*",
    "@libra/email": "*",
    "@libra/ui": "*",
    "@paralleldrive/cuid2": "^3.3.0",
    "better-auth-harmony": "^1.2.5",
    "date-fns": "^4.1.0",
    "ioredis": "^5.4.2",
    "sonner": "^2.0.7",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@libra/typescript-config": "*",
    "@better-auth/cli": "^1.3.16"
  }
}
